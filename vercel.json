{
  "version": 2,
  "name": "wedding-memory-nextjs",
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "build": {
    "env": {
      "PRISMA_GENERATE_DATAPROXY": "true"
    }
  },
  "env": {
    "DATABASE_URL": "@database_url",
    "NODE_ENV": "production"
  }
}
